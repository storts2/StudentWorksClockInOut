<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentWorksClockInOut.MainPage">

    <Grid RowDefinitions="Auto, *" RowSpacing="20" Padding="20">
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="40">
            <Label Grid.Row="0"
               Text="STUDENT WORKS CLOCK IN AND OUT SYSTEM"
               FontSize="Title"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
            <Image Source="student_works_logo.png" HeightRequest="150"/>
        </HorizontalStackLayout>
        
        <Grid ColumnDefinitions="*, *" RowDefinitions="*, *"
              Grid.Row="1"
              RowSpacing="20" ColumnSpacing="20">
            <Button Grid.Column="0" Grid.Row="0"
                    Text="CLOCK IN"
                    Clicked="OnClockIn"/>
            <Button Grid.Column="0" Grid.Row="1"
                    Text="CLOCK OUT"
                    Clicked="OnClockOut"/>
            <VerticalStackLayout Grid.Column="1" Grid.RowSpan="2"
                                 VerticalOptions="Center"
                                 Spacing="20">
                <Entry x:Name="_emplyeeIdEntry" 
                       Placeholder="Enter ID Here"/>
                <Button Text="SUBMIT"
                        Clicked="OnSubmit"/>
                <Label x:Name="_employeeDetails" 
                       Text="Signed Out: Welcome ... User"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
